      "updated": 1774552459543,
      "link": null,
      "locked": false,
      "text": "int maxSequence = 0;\nfor(int num : nums){\nif(!set.contains(num-1)){\n   int currentNum = num;\n   int currentSteak = 1;\n\nwhile(set.contains(currentNum+1){\n   currentNum++;\n   currentStreak++;\n}\nmaxSequence = Math.max(currentStreak,\nmaxSquence)\n}\n\nreturn maxSequence",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "int maxSequence = 0;\nfor(int num : nums){\nif(!set.contains(num-1)){\n   int currentNum = num;\n   int currentSteak = 1;\n\nwhile(set.contains(currentNum+1){\n   currentNum++;\n   currentStreak++;\n}\nmaxSequence = Math.max(currentStreak,\nmaxSquence)\n}\n\nreturn maxSequence",
      "autoResize": true,
      "lineHeight": 1.25
    },
